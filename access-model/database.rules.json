      "ai":          { ".read": "auth != null && (auth.uid === 'CuJigrzCbRfFFsM7uqe0mix46xH3' || auth.uid === 'g4stabGPKiWAE23NTw6oUsqawWf1' || root.child('autoflag/admins_uid').child(auth.uid).exists() || root.child('autoflag/installers').child(auth.uid).exists())", ".write": "auth != null && (auth.uid === 'CuJigrzCbRfFFsM7uqe0mix46xH3' || auth.uid === 'g4stabGPKiWAE23NTw6oUsqawWf1' || root.child('autoflag/admins_uid').child(auth.uid).exists() || root.child('autoflag/installers').child(auth.uid).exists())" },
      "misc":        { ".read": "auth != null && (auth.uid === 'CuJigrzCbRfFFsM7uqe0mix46xH3' || auth.uid === 'g4stabGPKiWAE23NTw6oUsqawWf1' || root.child('autoflag/admins_uid').child(auth.uid).exists() || root.child('autoflag/installers').child(auth.uid).exists())", ".write": "auth != null && (auth.uid === 'CuJigrzCbRfFFsM7uqe0mix46xH3' || auth.uid === 'g4stabGPKiWAE23NTw6oUsqawWf1' || root.child('autoflag/admins_uid').child(auth.uid).exists() || root.child('autoflag/installers').child(auth.uid).exists())" },
      "suggestions": { ".read": "auth != null && (auth.uid === 'CuJigrzCbRfFFsM7uqe0mix46xH3' || auth.uid === 'g4stabGPKiWAE23NTw6oUsqawWf1' || root.child('autoflag/admins_uid').child(auth.uid).exists() || root.child('autoflag/installers').child(auth.uid).exists())", ".write": "auth != null && (auth.uid === 'CuJigrzCbRfFFsM7uqe0mix46xH3' || auth.uid === 'g4stabGPKiWAE23NTw6oUsqawWf1' || root.child('autoflag/admins_uid').child(auth.uid).exists() || root.child('autoflag/installers').child(auth.uid).exists())" }
