    // ============================ VERITAS ============================
    // Role-based, roster-gated to match the Veritas client. UNLIKE the other
    // apps, Veritas has no syncAccess function and no UID-mirror node: the
    // client resolves roles CLIENT-side by reading the email-keyed roster at
    // veritas/people/{emailKey}.role. So these rules read that roster directly,
    // transforming auth.token.email with the SAME emailToKey escaping the
    // client uses (global replace, same order: . # $ [ ] /). RTDB .replace()
    // is global, so it matches the client's /g regex chain exactly.
    //   admin  = root UID  OR  people/{ek}.role === 'admin'
    //   mod    = admin     OR  people/{ek}.role === 'moderator'   (canModerate)
    //   member = admin/mod OR  people/{ek}.role === 'user'
    // Cascade rule (see header #1): grants are pushed to the LEAF. Top-level
    // .read/.write are admin-ONLY — this does NOT loosen children for
    // non-admins (admin ⊇ mod ⊇ member), it keeps `people` private from
    // members, and it lets the admin-only Data modal export (reads /veritas)
    // and restore (writes /veritas whole node) keep working.
    "veritas": {
      ".read":  "auth != null && (auth.uid === 'CuJigrzCbRfFFsM7uqe0mix46xH3' || auth.uid === 'g4stabGPKiWAE23NTw6oUsqawWf1' || (auth.token.email != null && root.child('veritas/people').child(auth.token.email.toLowerCase().replace('.', '_').replace('#', '_HASH_').replace('$', '_DOL_').replace('[', '_OB_').replace(']', '_CB_').replace('/', '_FS_')).child('role').val() === 'admin'))",
      ".write": "auth != null && (auth.uid === 'CuJigrzCbRfFFsM7uqe0mix46xH3' || auth.uid === 'g4stabGPKiWAE23NTw6oUsqawWf1' || (auth.token.email != null && root.child('veritas/people').child(auth.token.email.toLowerCase().replace('.', '_').replace('#', '_HASH_').replace('$', '_DOL_').replace('[', '_OB_').replace(']', '_CB_').replace('/', '_FS_')).child('role').val() === 'admin'))",

      // Legacy/stale UID-mirror node from the generic scaffold — never trusted
      // by these rules. Lock writes so nobody can plant junk under it.
      "admins_uid": { ".write": false },

      // People roster (emailKey -> {role,name,...}). Admins read/write the whole
      // roster; every signed-in user may read ONLY their own record so the
      // client's resolveRole() can resolve a moderator/user's role.
