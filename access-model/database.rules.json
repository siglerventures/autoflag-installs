        "$ek": {
          ".read": "auth != null && auth.token.email != null && $ek === auth.token.email.toLowerCase().replace('.', '_').replace('#', '_HASH_').replace('$', '_DOL_').replace('[', '_OB_').replace(']', '_CB_').replace('/', '_FS_')"
